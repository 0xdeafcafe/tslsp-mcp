{
  "name": "tslsp-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing the TypeScript language server (tsgo) — rename, references, definitions, hover, symbols, diagnostics.",
  "type": "module",
  "bin": {
    "tslsp-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@typescript/native-preview": "7.0.0-dev.20260506.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/ui": "^4.1.5",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.29.3"
}
